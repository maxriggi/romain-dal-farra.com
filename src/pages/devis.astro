---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Demander un devis — Romain Dal Farra"
  description="Obtenez votre devis personnalisé pour la production de vos vidéos. Réponse sous 24h."
>
  <Nav />

  <section class="devis-hero">
    <div class="devis-hero__content">
      <p class="devis-hero__note">
        Pour les alternances, stages et collaborations, veuillez ignorer ce formulaire et envoyer un mail ici :
        <a href="mailto:contact@romaindalfarra.com">contact@romaindalfarra.com</a>
      </p>
      <h1 class="devis-hero__title">Dites-nous en plus sur votre projet vidéo</h1>
      <p class="devis-hero__subtitle">Répondez à quelques questions rapides pour qu'on vous oriente efficacement.</p>
      <button class="devis-hero__start" id="startBtn">
        Commencer
      </button>
      <p class="devis-hero__time">
        <svg viewBox="0 0 24 24" class="devis-hero__clock"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Cela prend 1 minute
      </p>
    </div>
  </section>

  <!-- Multi-step form -->
  <section class="devis-form" id="devisForm" style="display:none;">
    <div class="devis-form__progress">
      <div class="devis-form__progress-bar" id="progressBar"></div>
    </div>

    <!-- Step 1 -->
    <div class="devis-step active" data-step="1">
      <span class="devis-step__num">1 → 7</span>
      <h2 class="devis-step__title">Quel est votre objectif principal ?</h2>
      <p class="devis-step__hint">Choisissez-en autant que vous voulez</p>
      <div class="devis-step__options devis-step__options--multi" data-name="objectif">
        <label class="devis-option"><input type="checkbox" name="objectif" value="Créer du contenu de communication pour mon entreprise"><span>A</span> Créer du contenu de communication pour mon entreprise</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Créer un contenu vidéo en motion design"><span>B</span> Créer un contenu vidéo en motion design</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Filmer un événement"><span>C</span> Filmer un événement (conférence, concert, table ronde, mariage)</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Photographier un événement"><span>D</span> Photographier un événement (conférence, concert, table ronde, mariage)</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Améliorer ma visibilité / mon image de marque"><span>E</span> Améliorer ma visibilité / mon image de marque</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Lancer un produit"><span>F</span> Lancer un produit</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Faire un reportage ou une interview"><span>G</span> Faire un reportage ou une interview</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Développer une vraie stratégie de contenu vidéo"><span>H</span> Développer une vraie stratégie de contenu vidéo</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Créer du contenu court pour les réseaux"><span>I</span> Créer du contenu court pour les réseaux (TikTok, Reels…)</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Diffusion et captation en direct (Livestream)"><span>J</span> Diffusion et captation d'une émission en direct (Livestream)</label>
        <label class="devis-option"><input type="checkbox" name="objectif" value="Prise de vue aérienne"><span>K</span> Prise de vue aérienne</label>
      </div>
      <button class="devis-step__ok" data-next="2">Ok</button>
    </div>

    <!-- Step 2 -->
    <div class="devis-step" data-step="2">
      <span class="devis-step__num">2 → 7</span>
      <h2 class="devis-step__title">Où en êtes-vous dans votre projet ?</h2>
      <div class="devis-step__options devis-step__options--single" data-name="avancement">
        <label class="devis-option"><input type="radio" name="avancement" value="J'ai déjà un brief ou une idée claire"><span>A</span> J'ai déjà un brief ou une idée claire</label>
        <label class="devis-option"><input type="radio" name="avancement" value="J'ai besoin d'aide pour structurer le projet"><span>B</span> J'ai besoin d'aide pour structurer le projet</label>
        <label class="devis-option"><input type="radio" name="avancement" value="Je veux juste une première estimation"><span>C</span> Je veux juste une première estimation</label>
      </div>
      <button class="devis-step__ok" data-next="3">Ok</button>
    </div>

    <!-- Step 3 -->
    <div class="devis-step" data-step="3">
      <span class="devis-step__num">3 → 7</span>
      <h2 class="devis-step__title">Quel est votre budget ?</h2>
      <p class="devis-step__hint">As-tu une fourchette budgétaire en tête ?</p>
      <div class="devis-step__options devis-step__options--single" data-name="budget">
        <label class="devis-option"><input type="radio" name="budget" value="Moins de 2 000 €"><span>A</span> Moins de 2 000 €</label>
        <label class="devis-option"><input type="radio" name="budget" value="2 000 € - 5 000 €"><span>B</span> 2 000 € - 5 000 €</label>
        <label class="devis-option"><input type="radio" name="budget" value="5 000 € - 10 000 €"><span>C</span> 5 000 € - 10 000 €</label>
        <label class="devis-option"><input type="radio" name="budget" value="10 000 € - 20 000 €"><span>D</span> 10 000 € - 20 000 €</label>
        <label class="devis-option"><input type="radio" name="budget" value="> à 20 000 €"><span>E</span> &gt; à 20 000 €</label>
      </div>
      <button class="devis-step__ok" data-next="4">Ok</button>
    </div>

    <!-- Step 4 -->
    <div class="devis-step" data-step="4">
      <span class="devis-step__num">4 → 7</span>
      <h2 class="devis-step__title">Où seront diffusées les vidéos ?</h2>
      <p class="devis-step__hint">Choisissez-en autant que vous voulez</p>
      <div class="devis-step__options devis-step__options--multi" data-name="diffusion">
        <label class="devis-option"><input type="checkbox" name="diffusion" value="TV et cinéma"><span>A</span> TV et cinéma</label>
        <label class="devis-option"><input type="checkbox" name="diffusion" value="Instagram / TikTok / Shorts"><span>B</span> Instagram / TikTok / Shorts</label>
        <label class="devis-option"><input type="checkbox" name="diffusion" value="LinkedIn / YouTube / Facebook"><span>C</span> LinkedIn / YouTube / Facebook</label>
        <label class="devis-option"><input type="checkbox" name="diffusion" value="Site internet / newsletters"><span>D</span> Site internet / newsletters</label>
        <label class="devis-option"><input type="checkbox" name="diffusion" value="Diffusion live"><span>E</span> Diffusion live</label>
        <label class="devis-option"><input type="checkbox" name="diffusion" value="Usage interne (recrutement, onboarding, etc.)"><span>F</span> Usage interne (recrutement, onboarding, etc.)</label>
        <label class="devis-option"><input type="checkbox" name="diffusion" value="Usage externe (salon, conférences, etc.)"><span>H</span> Usage externe (salon, conférences, etc.)</label>
      </div>
      <button class="devis-step__ok" data-next="5">Ok</button>
    </div>

    <!-- Step 5 -->
    <div class="devis-step" data-step="5">
      <span class="devis-step__num">5 → 7</span>
      <h2 class="devis-step__title">Voulez-vous partager un lien utile ?</h2>
      <p class="devis-step__hint">(site web, Insta, vidéo de référence)</p>
      <div class="devis-step__input-wrap">
        <input type="url" name="lien" class="devis-step__input" placeholder="https://..." />
      </div>
      <button class="devis-step__ok" data-next="6">Ok</button>
    </div>

    <!-- Step 6 -->
    <div class="devis-step" data-step="6">
      <span class="devis-step__num">6 → 7</span>
      <h2 class="devis-step__title">Quelle est votre date de lancement ?</h2>
      <p class="devis-step__hint">Tu veux lancer ça quand ?</p>
      <div class="devis-step__options devis-step__options--single" data-name="delai">
        <label class="devis-option"><input type="radio" name="delai" value="Immédiatement"><span>A</span> Immédiatement</label>
        <label class="devis-option"><input type="radio" name="delai" value="Ce mois-ci"><span>B</span> Ce mois-ci</label>
        <label class="devis-option"><input type="radio" name="delai" value="D'ici 2 à 3 mois"><span>C</span> D'ici 2 à 3 mois</label>
        <label class="devis-option"><input type="radio" name="delai" value="Je ne sais pas encore"><span>D</span> Je ne sais pas encore</label>
      </div>
      <button class="devis-step__ok" data-next="7">Ok</button>
    </div>

    <!-- Step 7 - Contact info -->
    <div class="devis-step" data-step="7">
      <span class="devis-step__num">7 → 7</span>
      <h2 class="devis-step__title">Infos personnelles</h2>
      <div class="devis-step__fields">
        <div class="form-group">
          <label class="form-group__label" for="devisName">Nom et Prénom *</label>
          <input class="form-group__input" type="text" id="devisName" name="nom" required />
        </div>
        <div class="form-group">
          <label class="form-group__label" for="devisPhone">Numéro de téléphone *</label>
          <input class="form-group__input" type="tel" id="devisPhone" name="telephone" required />
        </div>
        <div class="form-group">
          <label class="form-group__label" for="devisEmail">E-mail *</label>
          <input class="form-group__input" type="email" id="devisEmail" name="email" required />
        </div>
        <div class="form-group">
          <label class="form-group__label" for="devisCompany">Entreprise / Particulier</label>
          <input class="form-group__input" type="text" id="devisCompany" name="entreprise" placeholder="Particulier" />
        </div>
      </div>
      <button class="devis-step__ok devis-step__ok--submit" id="submitBtn">Envoyer</button>
      <p class="devis-step__warning">N'envoyez jamais de mots de passe !</p>
    </div>

    <!-- Step 8 - Thank you -->
    <div class="devis-step" data-step="8">
      <div class="devis-merci">
        <h2 class="devis-merci__title">Merci beaucoup pour votre demande</h2>
        <p class="devis-merci__text">Nous sommes ravis de découvrir votre projet et de l'étudier avec attention afin de vous proposer une réponse la plus juste possible.</p>
        <p class="devis-merci__text">Vous recevrez un devis détaillé de notre part dans un délai de 24 heures. Si besoin, nous prendrons le temps de revenir vers vous pour affiner certains points et vous accompagner au mieux.</p>
        <p class="devis-merci__text">Au plaisir d'échanger avec vous très bientôt,<br /><strong>Romain Dal Farra</strong></p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  (function() {
    const startBtn = document.getElementById('startBtn');
    const form = document.getElementById('devisForm');
    const hero = document.querySelector('.devis-hero');
    const progressBar = document.getElementById('progressBar');
    const submitBtn = document.getElementById('submitBtn');
    const totalSteps = 7;

    if (!startBtn || !form) return;

    function showStep(n) {
      document.querySelectorAll('.devis-step').forEach(s => s.classList.remove('active'));
      const step = document.querySelector(`.devis-step[data-step="${n}"]`);
      if (step) step.classList.add('active');
      if (progressBar) progressBar.style.width = `${(Math.min(n, totalSteps) / totalSteps) * 100}%`;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    startBtn.addEventListener('click', () => {
      hero.style.display = 'none';
      form.style.display = 'block';
      showStep(1);
    });

    // Ok buttons
    document.querySelectorAll('.devis-step__ok[data-next]').forEach(btn => {
      btn.addEventListener('click', () => {
        const next = parseInt(btn.getAttribute('data-next') || '1');
        showStep(next);
      });
    });

    // Option selection highlight — use setTimeout to read state after browser toggle
    document.querySelectorAll('.devis-option').forEach(opt => {
      opt.addEventListener('click', () => {
        const input = opt.querySelector('input') as HTMLInputElement;
        if (!input) return;
        setTimeout(() => {
          if (input.type === 'radio') {
            opt.closest('.devis-step__options')?.querySelectorAll('.devis-option').forEach(o => o.classList.remove('selected'));
            if (input.checked) opt.classList.add('selected');
          } else {
            opt.classList.toggle('selected', input.checked);
          }
        }, 0);
      });
    });

    // Submit
    if (submitBtn) {
      submitBtn.addEventListener('click', async () => {
        const name = (document.getElementById('devisName') as HTMLInputElement)?.value;
        const email = (document.getElementById('devisEmail') as HTMLInputElement)?.value;
        if (!name || !email) { alert('Veuillez remplir les champs obligatoires.'); return; }

        // Collect all data
        const data: Record<string, string> = {};
        data['Nom'] = name;
        data['Email'] = email;
        data['Telephone'] = (document.getElementById('devisPhone') as HTMLInputElement)?.value || '';
        data['Entreprise'] = (document.getElementById('devisCompany') as HTMLInputElement)?.value || 'Particulier';

        // Checkboxes & radios
        document.querySelectorAll('.devis-step__options').forEach(group => {
          const field = group.getAttribute('data-name') || '';
          const checked = group.querySelectorAll('input:checked');
          data[field] = Array.from(checked).map(c => (c as HTMLInputElement).value).join(', ');
        });

        // Text inputs
        const lien = (document.querySelector('input[name="lien"]') as HTMLInputElement)?.value;
        if (lien) data['Lien'] = lien;

        // Send via Formspree
        try {
          await fetch('https://formspree.io/f/xqewqzre', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
        } catch(e) { /* silent */ }

        showStep(8);

        // Redirect after 8 seconds
        setTimeout(() => {
          const base = document.querySelector('meta[name="base"]')?.getAttribute('content') || '';
          window.location.href = base + '/';
        }, 8000);
      });
    }
  })();
</script>

<style>
  /* Hero */
  .devis-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem 4rem;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(212, 160, 74, 0.05) 0%, transparent 70%),
      var(--black-deep);
  }
  .devis-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--white);
    margin-bottom: 1rem;
    max-width: 700px;
  }
  .devis-hero__subtitle {
    font-size: 1.05rem;
    color: var(--gray-lighter);
    max-width: 550px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .devis-hero__note {
    font-size: 0.8rem;
    color: var(--gray);
    margin-bottom: 2rem;
    max-width: 500px;
  }
  .devis-hero__note a {
    color: var(--amber);
  }
  .devis-hero__start {
    display: inline-block;
    padding: 1rem 3rem;
    background: var(--amber);
    color: var(--black-deep);
    border: none;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-smooth);
  }
  .devis-hero__start:hover {
    background: var(--amber-light);
    transform: translateY(-2px);
  }
  .devis-hero__time {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--gray);
  }
  .devis-hero__clock {
    width: 14px;
    height: 14px;
    stroke: var(--gray);
    fill: none;
    stroke-width: 1.5;
  }

  /* Form */
  .devis-form {
    min-height: 100vh;
    padding: 0;
    background: var(--black-deep);
  }
  .devis-form__progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gray-dark);
    z-index: 9999;
  }
  .devis-form__progress-bar {
    height: 100%;
    width: 0;
    background: var(--amber);
    transition: width 0.6s var(--ease-cinematic);
  }

  /* Steps */
  .devis-step {
    display: none;
    max-width: 700px;
    margin: 0 auto;
    padding: 15vh 2rem 4rem;
    animation: stepIn 0.5s var(--ease-cinematic);
  }
  .devis-step.active {
    display: block;
  }
  @keyframes stepIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .devis-step__num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--amber);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 1rem;
  }
  .devis-step__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    color: var(--white);
    margin-bottom: 0.5rem;
  }
  .devis-step__hint {
    font-size: 0.85rem;
    color: var(--gray-light);
    margin-bottom: 2rem;
  }

  /* Options */
  .devis-step__options {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .devis-option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    border: 1px solid var(--gray-dark);
    background: var(--black-card);
    color: var(--gray-lighter);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-smooth);
  }
  .devis-option input {
    display: none;
  }
  .devis-option span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border: 1px solid var(--gray-dark);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gray);
    flex-shrink: 0;
    transition: all var(--duration-fast) var(--ease-smooth);
  }
  .devis-option:hover {
    border-color: var(--amber-dim);
  }
  .devis-option.selected {
    border-color: var(--amber);
    background: rgba(212, 160, 74, 0.08);
    color: var(--white);
  }
  .devis-option.selected span {
    background: var(--amber);
    border-color: var(--amber);
    color: var(--black-deep);
  }

  /* Text input */
  .devis-step__input-wrap {
    margin-bottom: 2rem;
  }
  .devis-step__input {
    width: 100%;
    padding: 0.85rem 1.25rem;
    background: var(--black-card);
    border: 1px solid var(--gray-dark);
    color: var(--white);
    font-size: 0.9rem;
    font-family: var(--font-body);
    transition: border-color var(--duration-fast) var(--ease-smooth);
  }
  .devis-step__input:focus {
    outline: none;
    border-color: var(--amber);
  }

  /* Fields */
  .devis-step__fields {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  /* Ok button */
  .devis-step__ok {
    display: inline-block;
    padding: 0.75rem 2.5rem;
    background: var(--amber);
    color: var(--black-deep);
    border: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-smooth);
  }
  .devis-step__ok:hover {
    background: var(--amber-light);
    transform: translateY(-2px);
  }
  .devis-step__warning {
    margin-top: 1rem;
    font-size: 0.75rem;
    color: var(--gray);
  }

  /* Merci */
  .devis-merci {
    text-align: center;
    padding: 2rem 0;
  }
  .devis-merci__title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--amber);
    margin-bottom: 2rem;
  }
  .devis-merci__text {
    font-size: 1rem;
    color: var(--gray-lighter);
    line-height: 1.8;
    max-width: 550px;
    margin: 0 auto 1.5rem;
  }

  @media (max-width: 768px) {
    .devis-step {
      padding: 12vh 1.5rem 3rem;
    }
  }
</style>
