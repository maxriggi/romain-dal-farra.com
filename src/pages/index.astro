---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import SectionCta from '../components/SectionCta.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import Services from '../components/Services.astro';
import Filmography from '../components/Filmography.astro';
import Skills from '../components/Skills.astro';
import Partners from '../components/Partners.astro';
import InstagramBanner from '../components/InstagramBanner.astro';
import ContactTeaser from '../components/ContactTeaser.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <Hero />
  <div class="section-separator"></div>
  <Services variant="teaser" />
  <SectionCta href="/services" label="Tous les services" />
  <div class="section-separator"></div>
  <About variant="teaser" />
  <SectionCta href="/a-propos" label="En savoir plus" />
  <div class="section-separator"></div>
  <FeaturedProjects />
  <SectionCta href="/filmographie" label="Voir la filmographie" />
  <div class="section-separator"></div>
  <Filmography variant="teaser" />
  <SectionCta href="/filmographie" label="Tous les projets" />
  <div class="section-separator"></div>
  <Skills variant="teaser" />
  <SectionCta href="/competences" label="Voir les compétences" />
  <div class="section-separator"></div>
  <Partners />
  <div class="section-separator"></div>
  <InstagramBanner />
  <div class="section-separator"></div>
  <ContactTeaser />
  <Footer />
</BaseLayout>
