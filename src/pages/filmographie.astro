---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Filmography from '../components/Filmography.astro';
import SectionCta from '../components/SectionCta.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import yaml from 'yaml';

const allProjects = yaml.parse(readFileSync('src/data/projects.yaml', 'utf-8'));
const totalProjects = allProjects.length;
const years = [...new Set(allProjects.map((p: any) => p.year))].sort();
const firstYear = years[0];
const lastYear = years[years.length - 1];
---

<BaseLayout
  title="Filmographie — Romain Dal Farra | Films, Clips, Publicités"
  description="Portfolio de Romain Dal Farra : 22 projets audiovisuels depuis 2015. Films institutionnels, clips musicaux, courts métrages, publicités. Réalisateur et directeur photo freelance."
  ogTitle="Filmographie — Romain Dal Farra"
  ogDescription="22 projets audiovisuels : films, clips, pubs, institutionnels. Réalisateur et directeur photo freelance Metz."
>
  <Nav />
  <PageHero
    label="Filmographie"
    title="Projets sélectionnés"
    subtitle={`${totalProjects} projets de ${firstYear} à ${lastYear} — films, clips, pubs, institutionnels.`}
  />

  <!-- Stats bar -->
  <section class="stats section">
    <div class="section__container">
      <div class="stats__grid">
        <div class="stats__item reveal">
          <span class="stats__number">{totalProjects}</span>
          <span class="stats__label">Projets</span>
        </div>
        <div class="stats__item reveal">
          <span class="stats__number">{lastYear - firstYear}+</span>
          <span class="stats__label">Années d'expérience</span>
        </div>
        <div class="stats__item reveal">
          <span class="stats__number">4</span>
          <span class="stats__label">Casquettes</span>
        </div>
      </div>
    </div>
  </section>

  <Filmography variant="full" showHeader={false} />

  <div class="section-separator"></div>

  <section class="cta-section section">
    <div class="section__container" style="text-align: center;">
      <p class="cta-section__text">Vous avez un projet ? Je suis disponible.</p>
      <SectionCta href="/contact" label="Me contacter" />
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .stats {
    background: transparent;
    padding: 2rem 0;
  }
  .stats__grid {
    display: flex;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
  }
  .stats__item {
    text-align: center;
  }
  .stats__number {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--amber);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .stats__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
  }
  .cta-section {
    background: transparent;
  }
  .cta-section__text {
    color: var(--gray-lighter);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }
</style>
