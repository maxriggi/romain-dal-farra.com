---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import About from '../components/About.astro';
import Partners from '../components/Partners.astro';
import SectionCta from '../components/SectionCta.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import yaml from 'yaml';

const aboutData = yaml.parse(readFileSync('src/data/about.yaml', 'utf-8'));

const parcours = [
  { year: '2012', label: 'Bac STI Electrotechnique — Metz' },
  { year: '2015', label: 'Licence Cinéma — IECA Nancy' },
  { year: '2015', label: 'Début activité freelance — Grand Est' },
  { year: '2016', label: 'Master Production & Réalisation documentaire — IECA' },
  { year: '2020', label: 'Expansion Luxembourg & international' },
  { year: "Auj.", label: 'Réalisateur, Dir. Photo & Technicien plateau' },
];
---

<BaseLayout
  title="À propos — Romain Dal Farra, Réalisateur & Dir. Photo | Metz"
  description="Découvrez le parcours de Romain Dal Farra, réalisateur et directeur de la photographie freelance basé à Metz. Formation IECA Nancy, expérience depuis 2015 en Grand Est et Luxembourg."
  ogTitle="À propos — Romain Dal Farra"
  ogDescription="Réalisateur et directeur de la photographie freelance. Parcours, formation et vision artistique."
>
  <Nav />
  <PageHero
    label="À propos"
    title="Romain Dal Farra"
    subtitle="Réalisateur & Directeur de la Photographie — Metz, Grand Est"
  />

  <About variant="full" showHeader={false} />

  <div class="section-separator"></div>

  <!-- Parcours timeline -->
  <section class="timeline section">
    <div class="section__container">
      <div class="timeline__wrapper">
        <div class="timeline__track" id="timelineTrack">
          <div class="timeline__line">
            <div class="timeline__line-fill" id="timelineFill"></div>
          </div>
          {parcours.map((item, i) => (
            <div class={`timeline__item ${i % 2 === 0 ? 'timeline__item--top' : 'timeline__item--bottom'}`} data-index={i}>
              <div class="timeline__dot"></div>
              <div class="timeline__content">
                <span class="timeline__year">{item.year}</span>
                <p class="timeline__label">{item.label}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="timeline__cta reveal">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cv-romain-dal-farra.pdf`} target="_blank" rel="noopener" class="btn-shutter">
          Télécharger mon CV
          <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <div class="section-separator"></div>

  <Partners />

  <div class="section-separator"></div>

  <section class="cta-section section">
    <div class="section__container" style="text-align: center;">
      <p class="cta-section__text">Envie de collaborer sur un projet ?</p>
      <SectionCta href="/contact" label="Me contacter" />
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  (function() {
    const track = document.getElementById('timelineTrack');
    const fill = document.getElementById('timelineFill');
    const items = track?.querySelectorAll('.timeline__item');
    if (!track || !fill || !items?.length) return;

    // Activate items on scroll into view
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const item = entry.target as HTMLElement;
          item.classList.add('active');
          // Update fill line to reach this item
          const trackRect = track.getBoundingClientRect();
          const itemRect = item.getBoundingClientRect();
          const progress = (itemRect.left + itemRect.offsetWidth / 2 - trackRect.left) / trackRect.scrollWidth * 100;
          fill.style.width = Math.min(progress, 100) + '%';
          observer.unobserve(item);
        }
      });
    }, { threshold: 0.5 });

    items.forEach(item => observer.observe(item));

    // Hover interaction
    items.forEach(item => {
      item.addEventListener('mouseenter', () => {
        items.forEach(i => i.classList.remove('hover'));
        item.classList.add('hover');
      });
      item.addEventListener('mouseleave', () => {
        item.classList.remove('hover');
      });
    });
  })();
</script>

<style>
  .timeline {
    background: linear-gradient(180deg, var(--black-deep) 0%, #0f0f0f 50%, var(--black-deep) 100%);
  }
  .timeline__wrapper {
    margin-top: 2rem;
    overflow-x: auto;
    overflow-y: visible;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .timeline__wrapper::-webkit-scrollbar { display: none; }
  .timeline__track {
    display: flex;
    position: relative;
    min-width: max-content;
    height: 280px;
    align-items: center;
    gap: 0;
  }
  .timeline__line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gray-dark);
    transform: translateY(-50%);
  }
  .timeline__line-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--amber-dim), var(--amber));
    transition: width 1s var(--ease-cinematic);
  }
  .timeline__item {
    position: relative;
    flex: 0 0 clamp(150px, 16vw, 200px);
    text-align: center;
    cursor: default;
    opacity: 0;
    transition: opacity 0.6s var(--ease-cinematic),
                transform 0.6s var(--ease-cinematic);
  }
  /* Quinconce : pairs en haut, impairs en bas */
  .timeline__item--top {
    align-self: flex-start;
    padding-top: 0;
    padding-bottom: 2rem;
    transform: translateY(-10px);
  }
  .timeline__item--top .timeline__content {
    padding-bottom: 1.5rem;
  }
  .timeline__item--top .timeline__dot {
    bottom: -7px;
    top: auto;
  }
  .timeline__item--bottom {
    align-self: flex-end;
    padding-bottom: 0;
    padding-top: 2rem;
    transform: translateY(10px);
  }
  .timeline__item--bottom .timeline__content {
    padding-top: 1.5rem;
  }
  .timeline__item--bottom .timeline__dot {
    top: -7px;
    bottom: auto;
  }
  .timeline__item.active {
    opacity: 1;
    transform: translateY(0);
  }
  .timeline__dot {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) scale(1);
    width: 14px;
    height: 14px;
    background: var(--black-deep);
    border: 2px solid var(--gray-dark);
    border-radius: 50%;
    transition: all 0.4s var(--ease-cinematic);
    z-index: 1;
  }
  .timeline__item.active .timeline__dot {
    border-color: var(--amber);
    background: var(--amber);
    box-shadow: 0 0 12px rgba(212, 160, 74, 0.4);
  }
  .timeline__item.hover .timeline__dot {
    transform: translateX(-50%) scale(1.4);
    box-shadow: 0 0 20px rgba(212, 160, 74, 0.6);
  }
  .timeline__year {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--gray);
    margin-bottom: 0.35rem;
    transition: color 0.3s var(--ease-smooth);
  }
  .timeline__item.active .timeline__year {
    color: var(--amber);
  }
  .timeline__label {
    font-size: 0.82rem;
    color: var(--gray-light);
    line-height: 1.5;
    transition: color 0.3s var(--ease-smooth);
  }
  .timeline__item.hover .timeline__label {
    color: var(--white);
  }
  .timeline__cta {
    margin-top: 3rem;
    text-align: center;
  }
  .timeline__cta .btn-shutter svg {
    width: 18px;
    height: 18px;
  }
  .cta-section {
    background: transparent;
  }
  .cta-section__text {
    color: var(--gray-lighter);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .timeline__item {
      flex: 0 0 150px;
    }
    .timeline__track {
      height: 240px;
    }
  }
</style>
