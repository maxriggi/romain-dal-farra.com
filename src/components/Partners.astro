---
import { readFileSync } from 'fs';
import yaml from 'yaml';
import { Image } from 'astro:assets';

const partners = yaml.parse(readFileSync('src/data/partners.yaml', 'utf-8'));

const partnerImages = import.meta.glob<{ default: ImageMetadata }>('../assets/partners/*.*', { eager: true });

function getPartnerImage(logo: string) {
  const key = `../assets/partners/${logo}`;
  return partnerImages[key]?.default;
}
---

<section class="partners section" id="partenaires" aria-label="Partenaires">
  <div class="section__container">
    <div class="reveal">
      <span class="section__label">Partenaires</span>
      <h2 class="section__heading">Ils m'ont fait confiance</h2>
      <div class="section__divider"></div>
    </div>

    <div class="partners__carousel-wrapper">
      <div class="partners__carousel" id="partnersCarousel">
        {partners.map((partner: any) => {
          const img = getPartnerImage(partner.logo);
          return (
            <div class="partners__logo">
              {img ? (
                <Image src={img} alt={partner.name} height={48} loading="lazy" />
              ) : (
                <span class="partners__logo-text">{partner.name}</span>
              )}
            </div>
          );
        })}
      </div>

      <div class="partners__dots" id="partnersDots">
        {partners.map((_: any, i: number) => (
          <button class={`partners__dot ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={`Partenaire ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const carousel = document.getElementById('partnersCarousel');
    const dots = document.querySelectorAll('#partnersDots .partners__dot');
    if (!carousel || !dots.length) return;

    carousel.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
        e.preventDefault();
        carousel.scrollLeft += e.deltaY;
      }
    }, { passive: false });

    let scrollTimeout: number;
    carousel.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const items = carousel.querySelectorAll('.partners__logo');
        if (!items.length) return;
        const itemWidth = (items[0] as HTMLElement).offsetWidth + 48; // width + gap
        const index = Math.round(carousel.scrollLeft / itemWidth);
        const clamped = Math.min(index, dots.length - 1);
        dots.forEach((d, i) => d.classList.toggle('active', i === clamped));
      }, 50);
    }, { passive: true });

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const index = Number(dot.getAttribute('data-index'));
        const items = carousel.querySelectorAll('.partners__logo');
        if (!items.length) return;
        const itemWidth = (items[0] as HTMLElement).offsetWidth + 48;
        carousel.scrollTo({ left: index * itemWidth, behavior: 'smooth' });
      });
    });
  })();
</script>

<style>
  .partners {
    background: linear-gradient(180deg, var(--black-deep) 0%, #0e0e0f 50%, var(--black-deep) 100%);
  }
  .partners__carousel-wrapper {
    mask-image: linear-gradient(90deg, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 5%, black 95%, transparent);
  }
  .partners__carousel {
    display: flex;
    gap: 3rem;
    align-items: center;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
    padding: 1rem 0;
  }
  .partners__carousel::-webkit-scrollbar { display: none; }
  .partners__logo {
    flex: 0 0 auto;
    height: 48px;
    display: flex;
    align-items: center;
    scroll-snap-align: start;
  }
  .partners__logo img {
    height: 48px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1) opacity(0.5);
    transition: filter 0.3s var(--ease-smooth);
  }
  .partners__logo:hover img {
    filter: grayscale(0) opacity(1);
  }
  .partners__logo-text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gray);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .partners__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }
  .partners__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1px solid var(--gray-dark);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background var(--duration-fast) var(--ease-smooth),
                border-color var(--duration-fast) var(--ease-smooth),
                transform var(--duration-fast) var(--ease-smooth);
  }
  .partners__dot:hover {
    border-color: var(--amber-dim);
  }
  .partners__dot.active {
    background: var(--amber);
    border-color: var(--amber);
    transform: scale(1.3);
  }
</style>
