---
const base = import.meta.env.BASE_URL;
---

<section class="contact-teaser section" aria-label="Contact">
  <div class="section__container">
    <div class="reveal">
      <span class="section__label">Contact</span>
      <p class="contact-teaser__text">Vous avez un projet de film, une idée de clip, un besoin en image ? Parlons-en.</p>
      <a href={`${base}/contact`} class="btn-shutter">
        Me contacter
        <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-teaser {
    text-align: center;
    background:
      radial-gradient(ellipse 60% 50% at 50% 80%, rgba(212, 160, 74, 0.04) 0%, transparent 70%),
      linear-gradient(180deg, var(--black-deep) 0%, #0f0e0c 30%, #12110f 60%, #0e0d0b 100%);
  }
  .contact-teaser__text {
    color: var(--gray-lighter);
    font-size: 1.05rem;
    max-width: 500px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }
</style>
