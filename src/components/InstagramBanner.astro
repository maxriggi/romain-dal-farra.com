---
import { Image } from 'astro:assets';

import img1 from '../assets/realisations/shooting-nathan-avery/arw07035.webp';
import img2 from '../assets/realisations/mariage-cyrielle-et-maxime/arw03737.webp';
import img3 from '../assets/realisations/interface/a7r02105.webp';
import img4 from '../assets/realisations/mariage-florian-cristina/arw1135.webp';
import img5 from '../assets/realisations/shooting-nathan-avery/arw06941.webp';
import img6 from '../assets/realisations/mariage-cyrielle-et-maxime/arw04044.webp';
import img7 from '../assets/realisations/interface/a7r04166-300ppi.webp';
import img8 from '../assets/realisations/mariage-florian-cristina/arw1848.webp';

const photos = [img1, img2, img3, img4, img5, img6, img7, img8];
const instagramUrl = 'https://www.instagram.com/romaindalfarra/';
---

<section class="insta section" aria-label="Instagram">
  <div class="section__container">
    <div class="reveal">
      <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="insta__header">
        <svg class="insta__icon" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
        <span class="insta__handle">@romaindalfarra</span>
      </a>
    </div>

    <div class="insta__grid">
      {photos.map((photo, i) => (
        <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="insta__item">
          <Image src={photo} alt={`Instagram photo ${i + 1}`} width={300} height={300} class="insta__img" loading="lazy" />
          <div class="insta__overlay">
            <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .insta {
    background: linear-gradient(180deg, var(--black-deep) 0%, #0f0f0f 50%, var(--black-deep) 100%);
  }
  .insta__header {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color var(--duration-fast) var(--ease-smooth);
  }
  .insta__header:hover {
    color: var(--amber);
  }
  .insta__icon {
    width: 24px;
    height: 24px;
    stroke: var(--amber);
    fill: none;
    stroke-width: 1.5;
  }
  .insta__handle {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--gray-lighter);
    transition: color var(--duration-fast) var(--ease-smooth);
  }
  .insta__header:hover .insta__handle {
    color: var(--amber);
  }
  .insta__grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 4px;
  }
  .insta__item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    display: block;
  }
  .insta__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2);
    transition: transform 0.6s var(--ease-smooth), filter 0.4s var(--ease-smooth);
  }
  .insta__item:hover .insta__img {
    transform: scale(1.08);
    filter: grayscale(0) brightness(0.7);
  }
  .insta__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s var(--ease-smooth);
  }
  .insta__item:hover .insta__overlay {
    opacity: 1;
  }
  .insta__overlay svg {
    width: 28px;
    height: 28px;
    stroke: var(--white);
    fill: none;
    stroke-width: 1.5;
  }

  @media (max-width: 1024px) {
    .insta__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (max-width: 480px) {
    .insta__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
